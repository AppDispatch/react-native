{
  "name": "@appdispatch/react-native",
  "version": "0.6.0",
  "description": "AppDispatch SDK for React Native — feature flags, health monitoring, and OTA updates",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "appdispatch",
    "feature-flags",
    "openfeature",
    "health-metrics",
    "ota-updates",
    "expo",
    "react-native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AppDispatch/react-native"
  },
  "license": "MIT",
  "dependencies": {
    "@openfeature/core": "^1.6.0",
    "@openfeature/react-sdk": "^1.2.1"
  },
  "peerDependencies": {
    "expo-updates": ">=0.20.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "expo-updates": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
